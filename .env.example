# Copie ce fichier en .env et renseigne ton client_id d'app Azure AD.
#
# Comment l'obtenir :
#  1. https://portal.azure.com -> Azure Active Directory -> App registrations -> New registration
#  2. Supported account types : "Personal Microsoft accounts only"
#  3. Onglet Authentication -> "Allow public client flows" = Yes
#  4. Onglet API permissions : ajoute le scope Xbox Live "XboxLive.signin" (délégué)
#  5. Copie l'Application (client) ID ci-dessous
#
# Note : l'app doit être approuvée pour Minecraft, sinon login_with_xbox renvoie 403.
# Approbation : https://aka.ms/mce-reviewappid
MS_CLIENT_ID=

# --- Mises à jour automatiques ---
# AUTONOME par défaut : l'app se met à jour depuis les Releases GitHub du dépôt
# public saliox/snipe-mc. Rien à configurer.
#
# Overrides optionnels :
#   UPDATE_REPO=owner/name       -> autre dépôt GitHub public
#   UPDATE_URL=http://ip:8770/   -> flux HTTP local (npm run serve:updates)
# UPDATE_REPO=
# UPDATE_URL=

# Mets DEBUG=1 pour afficher les stack traces complètes.
# DEBUG=1
